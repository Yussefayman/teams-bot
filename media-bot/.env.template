# media-bot (Component A) configuration. Copy to .env (gitignored) and fill in.
# On Windows/prod these are real Azure values; on a dev Mac use CALL_SOURCE=fake.

# --- audio source selection ---
CALL_SOURCE=fake                       # fake (mac/dev) | graph (Windows real meeting)
FAKE_WAV_PATH=/tmp/mahdar_input.wav    # required when CALL_SOURCE=fake (16k/16-bit/mono WAV)

# --- downstream services ---
STT_WS_BASE_URL=ws://127.0.0.1:8799    # STT WebSocket base (wss:// in prod)
ORCHESTRATOR_BASE_URL=http://127.0.0.1:8798

# --- audio dump (M1 proof) ---
DUMP_AUDIO=true
DUMP_DIR=data/dumps

# --- HTTP host ---
ASPNETCORE_URLS=http://127.0.0.1:8797

# --- Azure / Graph (only needed for CALL_SOURCE=graph on Windows) ---
BOT_APP_ID=
BOT_APP_SECRET=
TENANT_ID=
PUBLIC_HOSTNAME=
MEDIA_PORT=8445
CERT_THUMBPRINT=
RECONNECT_BUFFER_SECONDS=60
